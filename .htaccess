# Evita que el navegador cachee las páginas HTML del dashboard.
# Sin esto, tras cada deploy los usuarios pueden seguir viendo una versión
# vieja de una página (ej. proyecto.html) hasta que el caché expira por su
# cuenta, causando bugs "fantasma" que ya fueron corregidos en el código.
<IfModule mod_headers.c>
  <FilesMatch "\.html$">
    Header set Cache-Control "no-cache, must-revalidate"
  </FilesMatch>
</IfModule>
